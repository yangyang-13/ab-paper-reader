# AI服务配置
# 支持的AI服务商: openai, qwen, deepseek, moonshot, glm, custom
AI_PROVIDER=openai

# API密钥（必填）
AI_API_KEY=your-api-key-here

# 自定义API端点（可选，如果使用默认provider可以不填）
# AI_BASE_URL=https://api.openai.com/v1

# 模型名称（可选，如果使用默认provider可以不填）
# AI_MODEL=gpt-4o-mini

# 兼容旧配置
OPENAI_API_KEY=your-api-key-here

# ======================================
# 各服务商配置示例
# ======================================

# 1. OpenAI (默认)
# AI_PROVIDER=openai
# AI_API_KEY=sk-xxxxx
# AI_MODEL=gpt-4o-mini  # 或 gpt-4, gpt-3.5-turbo

# 2. 通义千问 (Qwen)
# AI_PROVIDER=qwen
# AI_API_KEY=sk-xxxxx
# AI_MODEL=qwen-plus  # 或 qwen-turbo, qwen-max

# 3. DeepSeek
# AI_PROVIDER=deepseek
# AI_API_KEY=sk-xxxxx
# AI_MODEL=deepseek-chat

# 4. Moonshot (Kimi)
# AI_PROVIDER=moonshot
# AI_API_KEY=sk-xxxxx
# AI_MODEL=moonshot-v1-8k  # 或 moonshot-v1-32k, moonshot-v1-128k

# 5. 智谱AI (GLM)
# AI_PROVIDER=glm
# AI_API_KEY=xxxxx
# AI_MODEL=glm-4

# 6. 自定义（兼容OpenAI接口的服务）
# AI_PROVIDER=custom
# AI_API_KEY=your-key
# AI_BASE_URL=https://your-api-endpoint.com/v1
# AI_MODEL=your-model-name

# 数据库配置（可选，默认使用SQLite）
# DATABASE_URL=sqlite:///./papers.db

# API配置
# API_HOST=0.0.0.0
# API_PORT=8000
